# Application
APP_NAME=Master Equipment List
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mel_db
DB_ECHO=false

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# First admin (used by scripts/create_admin.py)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=ChangeMe123!
FIRST_ADMIN_NAME=Administrator

# Microsoft Graph / OneDrive (Azure App Registration)
# Organization-level app — single client app accesses OneDrive for the whole org.
MS_TENANT_ID=891f1913-ea7e-40b2-93f7-4e347bb76ab0
MS_CLIENT_ID=a23fe24f-bdff-47db-b2ef-c1c3d9e6830d
MS_CLIENT_SECRET=V7F8Q~-jMli83tyAL9D2inH5CcckZVk264qSIdez
MS_REDIRECT_URI=http://localhost:8000/api/v1/onedrive/oauth/callback
# Comma-separated scopes
MS_SCOPES=Files.Read.All,Files.ReadWrite.All,offline_access,User.Read

# File storage (local cache for synced files before parsing)
STORAGE_ROOT=./storage

# OCR
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=C:\poppler\poppler-24.08.0\Library\bin

# Vision LLM (Anthropic). When ANTHROPIC_API_KEY is set, PFD and Vendor PDFs
# are extracted by Claude vision (handles any PFD layout robustly). Falls
# back to OCR if unset or if the call fails.
ANTHROPIC_API_KEY=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
VISION_MODEL=claude-sonnet-4-5-20250929
VISION_MAX_PAGES=4
VISION_RENDER_DPI=200
